<Window x:Class="Demo.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo"
        mc:Ignorable="d"
        Title="HistoryWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TextBlockPartnerName" Text="История продаж партнера" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Таблица вывода истории согласно требованиям Модуля №4 -->
        <DataGrid x:Name="DataGridHistory" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White">
            <DataGrid.Columns>
                <!-- Наименование продукции вытягиваем через навигационное свойство -->
                <DataGridTextColumn Header="Наименование продукции" Binding="{Binding ProductNavigation.name}" Width="2*"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding quantity}" Width="1*"/>
                <DataGridTextColumn Header="Дата продажи" Binding="{Binding data, StringFormat={}{0:dd.MM.yyyy}}" Width="1.2*"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding amount, StringFormat={}{0:C}}" Width="1*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Закрыть" Grid.Row="2" Width="100" Height="25" Click="BtnClose_Click" HorizontalAlignment="Right" Margin="0,10,0,0"/>
    </Grid>
</Window>
