<Window x:Class="Demo.PartnerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo"
        mc:Ignorable="d"
        Title="PartnerWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TextBlockTitle" Text="Добавление партнера" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Наименование:" Margin="0,5,0,2"/>
                <TextBox x:Name="TextBoxCompany"/>

                <TextBlock Text="Тип партнера:" Margin="0,5,0,2"/>
                <!-- Выпадающий список типов -->
                <ComboBox x:Name="ComboBoxType"/>

                <TextBlock Text="Рейтинг (целое неотрицательное число):" Margin="0,5,0,2"/>
                <TextBox x:Name="TextBoxRating"/>

                <TextBlock Text="ФИО директора:" Margin="0,5,0,2"/>
                <TextBox x:Name="TextBoxDirector"/>

                <TextBlock Text="Телефон:" Margin="0,5,0,2"/>
                <TextBox x:Name="TextBoxPhone"/>

                <TextBlock Text="Email:" Margin="0,5,0,2"/>
                <TextBox x:Name="TextBoxEmail"/>

                <TextBlock Text="ИНН:" Margin="0,5,0,2"/>
                <TextBox x:Name="TextBoxInn"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки навигации и сохранения -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Назад" Width="80" Height="25" Click="BtnCancel_Click" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Width="90" Height="25" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
